{
  "name": "danvers-opportunity-agent",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "cf:migrate:local": "bash scripts/run-migrations.sh local",
    "cf:migrate:remote": "bash scripts/run-migrations.sh remote",
    "cf:smoke": "bash scripts/smoke-test-ingest.sh",
    "test:parcel-matching": "node --test test/parcel-matching.test.mjs",
    "typecheck": "tsc --noEmit",
    "db:generate": "wrangler d1 migrations create OPPORTUNITY",
    "migrate:local": "wrangler d1 migrations apply OPPORTUNITY --local",
    "migrate:remote": "wrangler d1 migrations apply OPPORTUNITY --remote"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260416.0",
    "typescript": "^5.8.3",
    "wrangler": "^4.13.2"
  }
}
